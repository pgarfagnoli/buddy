#!/usr/bin/env python3
"""buddy-statusline — one-shot status line for Claude Code.

Prints a single compact buddy summary to stdout and exits.
Used by the statusLine setting in ~/.claude/settings.json.
"""
import sys
from pathlib import Path

_SERVER_DIR = Path(__file__).resolve().parent.parent / "server"
if str(_SERVER_DIR) not in sys.path:
    sys.path.insert(0, str(_SERVER_DIR))

from statusline import main  # noqa: E402

if __name__ == "__main__":
    sys.exit(main())
